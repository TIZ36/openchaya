{
  "name": "chatee-frontend",
  "version": "1.0.0",
  "description": "chatee 前端应用",
  "type": "module",
  "main": "electron/main.cjs",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "vite",
    "dev:electron": "concurrently -k \"vite --mode electron\" \"wait-on http://127.0.0.1:5177 && electron .\"",
    "build": "vite build",
    "build:electron": "vite build --mode electron",
    "preview": "vite preview",
    "electron:pack": "pnpm run build:electron && electron-builder",
    "clean": "rm -rf node_modules/.vite dist release"
  },
  "dependencies": {
    "@google/genai": "^1.31.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-toast": "^1.2.15",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.563.0",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^9.0.1",
    "react-router-dom": "^6.20.0",
    "react-virtuoso": "^4.18.1",
    "remark-gfm": "^4.0.0",
    "simple-icons": "^16.7.0",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.22",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.18",
    "typescript": "^5.3.3",
    "vite": "^7.2.4",
    "concurrently": "^9.1.2",
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.chatee.desktop",
    "productName": "Chatee",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "asar": true,
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
